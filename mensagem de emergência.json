        "id": "init_backoff",
        "type": "function",
        "z": "f4a232aa305cf9b9",
        "name": "Init (status ON, tent=0)",
        "func": "// CONFIG\nflow.set('green_instanceId', '7107348721');\nflow.set('green_token', '7df9c47cf3f94cc8b05f1326ae41a1c91a7dab9ca1984bbe8e');\nflow.set('dest_chatId', '553284324503@c.us');\nflow.set('em_msg', '⚠️ Botão de emergência pressionado. Vá até o local para confirmar que está tudo bem.');\n\n// Backoff\nflow.set('em_alert_active', true);\nflow.set('em_base_ms', 60_000);      // 1 min\nflow.set('em_max_ms', 15*60_000);    // teto 15 min\nflow.set('em_max_attempts', 8);      // opcional\n\nmsg.attempt = 0;\nreturn msg;",
        "outputs": 1,
