        "name": "attempt++ e reagendar",
        "func": "const active = flow.get('em_alert_active');\nif (!active) { node.status({fill:'grey',shape:'ring',text:'parado'}); return null; }\nmsg.attempt = (Number(msg.attempt) || 0) + 1;\nnode.status({fill:'green',shape:'dot',text:`enviado | próxima tent=${msg.attempt}`});\nreturn msg;",
