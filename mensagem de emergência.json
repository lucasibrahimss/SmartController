    {
        "id": "calc_delay",
        "type": "function",
        "z": "f4a232aa305cf9b9",
        "name": "Calc delay expo (1,2,4,8…)",
        "func": "const active = flow.get('em_alert_active');\nif (!active) { return null; }\nconst base = Number(flow.get('em_base_ms') || 60000);\nconst maxMs = Number(flow.get('em_max_ms') || 900000);\nconst maxA = Number(flow.get('em_max_attempts') || 99);\nconst k = Number(msg.attempt || 0);\nif (k >= maxA) { node.status({fill:'grey',shape:'ring',text:'fim por limite'}); return null; }\nconst delay = Math.min(base * Math.pow(2, k), maxMs);\nmsg.delay = delay; // usado pelo Delay\nnode.status({fill:'blue',shape:'dot',text:`tent=${k} | aguardar ${(delay/60000).toFixed(2)} min`});\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 1040,
        "y": 260,
        "wires": [
            [
                "delay_msg"
            ]
        ]
    },
