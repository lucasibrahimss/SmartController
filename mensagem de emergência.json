    {
        "id": "build_green_payload",
        "type": "function",
        "z": "f4a232aa305cf9b9",
        "name": "Montar POST Green-API",
        "func": "const instanceId = flow.get('green_instanceId');\nconst token      = flow.get('green_token');\nconst chatId     = flow.get('dest_chatId');\nconst text       = flow.get('em_msg');\nif(!instanceId||!token||!chatId){ node.error('Faltam credenciais/config.'); return null; }\nmsg.method = 'POST';\nmsg.headers = { 'Content-Type':'application/json' };\nmsg.url = `https://api.green-api.com/waInstance${instanceId}/sendMessage/${token}`;\nmsg.payload = { chatId, message: text };\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 990,
