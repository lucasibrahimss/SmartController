    {
        "id": "c51d28fddd1ad38e",
        "type": "function",
        "z": "6962c218adba2780",
        "name": "Montar mensagens (alexa_text / wp_text)",
        "func": "const grupo = msg.payload.config.payload;\n\nif (!grupo || !Array.isArray(grupo.medicamentos) || grupo.medicamentos.length === 0) {\n    node.warn(\"Grupo inválido ou sem medicamentos\");\n    return null;\n}\n\nfunction formatDose(q, tipo) {\n    q = parseInt(q, 10);\n    tipo = (tipo || '').toLowerCase().trim();\n\n    if (isNaN(q) || q <= 0) return 'dose prescrita';\n\n    if (tipo === 'comprimido' || tipo === 'comprimidos') {\n        return q === 1 ? '1 comprimido' : `${q} comprimidos`;\n    }\n\n    if (tipo === 'gota' || tipo === 'gotas') {\n        return q === 1 ? '1 gota' : `${q} gotas`;\n    }\n\n    if (tipo === 'ml') {\n        return `${q} ml`;\n    }\n\n    return `${q} ${tipo || 'unidade'}`;\n}\n\nconst itens = grupo.medicamentos.map((m, idx) => {\n    const dose = formatDose(m.quantidade, m.tipo);\n    return {\n        idx: idx + 1,\n        nome: m.remedio,\n        dose: dose,\n        textoCompleto: `${m.remedio}, ${dose}`\n    };\n});\n\n// ---------- TEXTO ALEXA ----------\nif (itens.length === 1) {\n    msg.alexa_text = `Lembrete de remédio. ${itens[0].nome}. Tomar ${itens[0].dose} agora.`;\n} else {\n    const listaFalavel = itens.map(i => `${i.nome}, ${i.dose}`).join('; ');\n    msg.alexa_text = `Lembrete de remédios. Agora você deve tomar: ${listaFalavel}.`;\n}\n\n// ---------- TEXTO WHATSAPP ----------\nif (itens.length === 1) {\n    msg.wp_text =\n        `⏰ *Lembrete de Medicação*\\n\\n` +\n        `Hora: *${grupo.hora}*\\n` +\n        `Medicamento: *${itens[0].nome}*\\n` +\n        `Dose: *${itens[0].dose}*`;\n} else {\n    msg.wp_text =\n        `⏰ *Lembrete de Medicação*\\n\\n` +\n        `Hora: *${grupo.hora}*\\n` +\n        `${itens.length} medicamentos a serem tomados agora:\\n\\n` +\n        itens.map(i => `• *${i.nome}* — ${i.dose}`).join('\\n');\n}\n\n// ---------- TELEFONE ----------\nmsg.telefone = grupo.telefone || \"\";\n\n// ---------- PAYLOAD MQTT ----------\nmsg.mqtt_payload = {\n    hora: grupo.hora,\n    total: itens.length,\n    itens: itens.map(i => ({\n        nome: i.nome,\n        dose: i.dose\n    }))\n};\n\nnode.warn({\n    alexa_text: msg.alexa_text,\n    wp_text: msg.wp_text,\n    mqtt_payload: msg.mqtt_payload\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
