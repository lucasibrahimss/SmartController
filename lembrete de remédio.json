    {
        "id": "57af458eb916e40c",
        "type": "function",
        "z": "6962c218adba2780",
        "name": "Gerar jobs para cron-plus",
        "func": "const linhas = Array.isArray(msg.payload) ? msg.payload : [];\n\nconst MAP = { dom: 0, seg: 1, ter: 2, qua: 3, qui: 4, sex: 5, sab: 6 };\n\nfunction diasParaCron(diasStr) {\n  const s = (diasStr || \"todos\").toLowerCase().replace(/\\s/g, \"\");\n  if (s === \"todos\" || s === \"\") return \"*\";\n  const nums = s.split(\",\").map(d => MAP[d]).filter(v => v !== undefined);\n  return nums.length ? nums.join(\",\") : \"*\";\n}\n\nfunction normalizaTel(tel) {\n  tel = String(tel || \"\").replace(/[^\\d]/g, \"\");\n\n  // Se vier com DDI +55 e celular com 9, remove o 9\n  tel = tel.replace(/^55(\\d{2})9(\\d{8})$/, \"55$1$2\");\n\n  // Se vier sem 55 e com 11 dígitos (DDD + 9 + número), adiciona 55 e remove o 9\n  if (/^\\d{11}$/.test(tel)) {\n    tel = tel.replace(/^(\\d{2})9(\\d{8})$/, \"55$1$2\");\n  }\n\n  // Se vier sem 55 e com 10 dígitos (DDD + número fixo/sem 9), adiciona 55\n  else if (/^\\d{10}$/.test(tel)) {\n    tel = \"55\" + tel;\n  }\n\n  return tel;\n}\n\n// filtra válidos\nconst validas = linhas.filter(r => {\n  const ativo = (r.ativo === undefined || r.ativo === \"\" || r.ativo === null)\n    ? \"1\"\n    : String(r.ativo).toLowerCase();\n\n  if (!(ativo === \"1\" || ativo === \"true\" || ativo === \"on\")) return false;\n  if (!r.hora) return false;\n\n  const m = String(r.hora).trim().match(/^([01]?\\d|2[0-3]):([0-5]\\d)(?::([0-5]\\d))?$/);\n  return !!m;\n});\n\n// agrupa por hora + dias + telefone\nconst grupos = {};\n\nvalidas.forEach((r) => {\n  const hora = String(r.hora).trim().slice(0, 5);\n  const dias = (r.dias || \"todos\").toLowerCase().replace(/\\s/g, \"\");\n  const tel = normalizaTel(r.telefone);\n  const chave = `${hora}|${dias}|${tel}`;\n\n  if (!grupos[chave]) {\n    grupos[chave] = {\n      hora,\n      dias,\n      telefone: tel,\n      medicamentos: []\n    };\n  }\n\n  grupos[chave].medicamentos.push({\n    remedio: r.remedio,\n    tipo: r.tipo,\n    quantidade: r.quantidade,\n    hora: hora\n  });\n});\n\n// cria jobs\nconst msgsAdd = [];\n\nObject.values(grupos).forEach((g, i) => {\n  const [hh, mm] = g.hora.split(\":\").map(v => parseInt(v, 10));\n  const dow = diasParaCron(g.dias);\n  const expression = `${mm} ${hh} * * ${dow}`;\n  const name = `grupo_${String(hh).padStart(2, \"0\")}${String(mm).padStart(2, \"0\")}_${g.dias || \"todos\"}_${i}`;\n\n  msgsAdd.push({\n    payload: {\n      command: \"add\",\n      name,\n      topic: name,\n      expression,\n      timezone: \"America/Sao_Paulo\",\n      payload: {\n        type: \"disparo_remedio\",\n        hora: g.hora,\n        dias: g.dias,\n        telefone: g.telefone,\n        medicamentos: g.medicamentos\n      }\n    }\n  });\n});\n\nconst msgRemove = { payload: { command: \"remove-all-jobs\" } };\n\nreturn [[msgRemove], msgsAdd];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 950,
        "y": 120,
