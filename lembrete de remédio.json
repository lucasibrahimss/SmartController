        "name": "Green-API request",
        "func": "// Substitua pelos seus IDs válidos da Green-API\nconst ID = \"7107348721\"; // waInstanceId\nconst TOKEN = \"7df9c47cf3f94cc8b05f1326ae41a1c91a7dab9ca1984bbe8e\"; // apiTokenInstance\n\nconst numero = msg.telefone || \"\";\nif (!numero) {\n  node.status({fill:\"yellow\",shape:\"ring\",text:\"sem telefone\"});\n  return null;\n}\n\nmsg.method = \"POST\";\nmsg.url = `https://api.green-api.com/waInstance${ID}/sendMessage/${TOKEN}`;\nmsg.headers = {\"Content-Type\":\"application/json\"};\nmsg.payload = {\n  chatId: `${numero}@c.us`,\n  message: msg.wp_text\n};\nreturn msg;",
