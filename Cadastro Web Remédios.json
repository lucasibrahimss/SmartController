    {
        "id": "fn_excluir_remedio",
        "type": "function",
        "z": "tab_remedios_web_01",
        "name": "Excluir remédio da lista",
        "func": "const lista = Array.isArray(msg.payload) ? msg.payload : [];\nconst body = msg.req.body || {};\nconst idExcluir = String(body.id || \"\");\n\nconst novaLista = lista.filter(item => String(item.id || \"\") !== idExcluir);\n\nmsg.payload = JSON.stringify(novaLista, null, 2);\nreturn msg;",
