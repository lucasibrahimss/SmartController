    {
        "id": "fn_adicionar_remedio",
        "type": "function",
        "z": "tab_remedios_web_01",
        "name": "Adicionar remédio à lista",
        "func": "const lista = Array.isArray(msg.payload) ? msg.payload : [];\nconst body = msg.req.body || {};\n\nlet dias = body.dias_semana || [];\n\nif (!Array.isArray(dias)) {\n    dias = dias ? [dias] : [];\n}\n\nconst novo = {\n    id: String(Date.now()),\n    hora: body.hora || \"\",\n    remedio: body.remedio || \"\",\n    tipo: body.tipo || \"\",\n    quantidade: body.quantidade || \"\",\n    telefone: body.telefone || \"\",\n    ativo: body.ativo || \"1\",\n    dias: dias.join(\",\"),\n    inicio: body.inicio || \"\"\n};\n\nlista.push(novo);\n\nmsg.payload = JSON.stringify(lista, null, 2);\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
